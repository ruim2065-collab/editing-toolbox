{
  "functions": {
    "api/fetch.js": {
      "memory": 512,
      "maxDuration": 10
    },
    "api/vision.js": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "api/data/font-screenshot-index.json"
    },
    "api/auth.js": {
      "memory": 512,
      "maxDuration": 10
    },
    "api/record.js": {
      "memory": 512,
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
